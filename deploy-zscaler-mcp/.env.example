# Example configuration for Zscaler MCP Deployer
# Copy this file to .env and fill in your actual credentials
#
# Zscaler Configuration
ZSCALER_CLOUD=zscaler
ZSCALER_USERNAME=your_email@example.com
ZSCALER_PASSWORD=your_password
ZSCALER_API_KEY=your_32_character_hex_api_key

# AWS Configuration (optional - uses default profile if not set)
# AWS_PROFILE=default
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key